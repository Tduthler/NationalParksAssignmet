<xsd:schema xsd="http://www.w3.org/2001/XMLSchema" xmlns="https://tduthler.github.io/NationalParksAssignmet/NationalParks.xml" targetNamespace="https://tduthler.github.io/NationalParksAssignmet/NationalParks.xml" elementFormDefault="qualified" attributeFormDefault="unqualified">
  <xsd:element name="NationalParks">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="NationalPark" type="NationalParkType" maxOccurs="unbounded"/>
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element> 
  <xsd:complexType name="NationalParkType">
    <xsd:sequence>
      <xsd:element name="Name"    type="xsd:string"/>
      <xsd:element name="Phone"   type="xsd:string" maxOccurs="unbounded"/>
      <xsd:element name="Address" type="AddressType"/>
    </xsd:sequence>
    <xsd:attribute name="Rating"       type="xsd:decimal" use="optional"/>
    <xsd:attribute name="NearestAirport" type="xsd:string" use="required"/>
  </xsd:complexType>
  <xsd:complexType name="AddressType">
    <xsd:sequence>
      <xsd:element name="Number" type="xsd:integer"/>
      <xsd:element name="Street" type="xsd:string"/>
      <xsd:element name="City"   type="xsd:string"/>
      <xsd:element name="State"  type="xsd:string"/>
      <xsd:element name="Zip"    type="xsd:string"/>
    </xsd:sequence>
  </xsd:complexType>
</xsd:schema>
